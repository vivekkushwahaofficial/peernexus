# =============================================================================
# PeerNexus Environment Variables Configuration Example
# Copy this file to '.env' at the project root and populate the actual secrets.
# =============================================================================

# ─── DATABASE CONFIGURATION ──────────────────────────────────────────────────
# Database name and user are set in docker-compose.yml as 'peernexus' and 'postgres'
# Choose a strong secret password for PostgreSQL production
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_URL=jdbc:postgresql://postgres:5432/peernexus
DB_USERNAME=postgres

# ─── SPRING AUTHENTICATION (JWT) ──────────────────────────────────────────────
# Generate a secure 256-bit base64 key for JWT signing:
# On Unix: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_BASE64_256BIT_KEY

# ─── APP BASE URLS & CORS ─────────────────────────────────────────────────────
# CORS - Comma-separated list of allowed frontend origins
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
APP_BACKEND_BASE_URL=http://localhost:8080

# Build argument for frontend SPA to route API queries to the correct domain
VITE_API_BASE_URL=http://localhost:8080

# Active Spring Profile (e.g., dev, prod)
SPRING_PROFILES_ACTIVE=dev

# ─── MAIL SERVER (SMTP) CONFIGURATION ─────────────────────────────────────────
# Required for user email verification and password reset flows
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-username@gmail.com
MAIL_PASSWORD=your-app-specific-password

# ─── CLOUDINARY CONFIGURATION ─────────────────────────────────────────────────
# Required for profile picture and chat media attachments
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
