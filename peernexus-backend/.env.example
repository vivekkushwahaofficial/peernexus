# ============================================================
# PeerNexus Backend — Environment Variables Template
# ============================================================
# Copy this file to .env (NOT committed to git) and fill in
# real values before starting the application.
#
# For Docker: use --env-file .env
# For IntelliJ / VS Code: set in Run Configuration > Environment
# For production (k8s / cloud): use Secrets or Secret Manager
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Use a dedicated service account; avoid 'root' in production.
DB_URL=jdbc:postgresql://localhost:5432/peernexus
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── JWT ──────────────────────────────────────────────────────
# Generate a cryptographically secure 256-bit base64 key:
#   openssl rand -base64 32
JWT_SECRET=CHANGE_ME_BASE64_256BIT_KEY

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash).
# Development: http://localhost:5173
# Production: https://peernexus.app
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Application base URL ─────────────────────────────────────
APP_BACKEND_BASE_URL=http://localhost:8080

# ── Mail (SMTP) ──────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=CHANGE_ME_APP_PASSWORD

# ── Cloudinary ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=CHANGE_ME
CLOUDINARY_API_KEY=CHANGE_ME
CLOUDINARY_API_SECRET=CHANGE_ME
